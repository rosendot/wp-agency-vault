# Database credentials — get these from LocalWP's Database tab
DB_NAME='local'
DB_USER='root'
DB_PASSWORD='root'
DB_HOST='localhost:10005'

# Environment: development, staging, or production
WP_ENV='development'

# Site URLs — match your LocalWP site domain
WP_HOME='http://your-site-name.local'
WP_SITEURL="${WP_HOME}/wp"

# Security salts — generate with:
# php -r "for(\$i=0;\$i<8;\$i++){echo bin2hex(random_bytes(32)).PHP_EOL;}"
AUTH_KEY='generate-me'
SECURE_AUTH_KEY='generate-me'
LOGGED_IN_KEY='generate-me'
NONCE_KEY='generate-me'
AUTH_SALT='generate-me'
SECURE_AUTH_SALT='generate-me'
LOGGED_IN_SALT='generate-me'
NONCE_SALT='generate-me'
